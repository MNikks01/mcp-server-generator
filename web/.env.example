# MCPForge web — environment.
# The app runs with NONE of these set (free generator + in-memory plan store).
# Add them to turn on the paid track and premium descriptions.

# --- Premium tool descriptions (Pro). Without it, the spec-derived fallback is used. ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Stripe (the paid track). Without these, /api/stripe/* returns 501 gracefully. ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_ID=price_...            # the Pro subscription price
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# --- Production persistence (swap the in-memory store for Postgres; schema in lib/db/schema.ts) ---
# DATABASE_URL=postgres://...

# --- Production auth (swap cookie identity for Clerk; see lib/identity.ts) ---
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...
# CLERK_SECRET_KEY=sk_...

# --- DEV ONLY: enables /api/dev/set-plan for testing the gating mechanic. NEVER in prod. ---
# ALLOW_DEV_PLAN=1
