# MCPForge web — environment.
# MCPForge is FREE & OPEN SOURCE. The app runs fully with NONE of these set
# (free generator + in-memory store). All variables below are optional upgrades.

# --- Premium tool descriptions (optional). Without it, the spec-derived fallback is used. ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Production persistence (optional; swap the in-memory store for Postgres; schema in lib/db/schema.ts) ---
# DATABASE_URL=postgres://...

# --- Production auth (optional; swap cookie identity for Clerk; see lib/identity.ts) ---
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...
# CLERK_SECRET_KEY=sk_...

# --- GitHub push (optional). A token can also be pasted per-request in the UI; never stored. ---
# GITHUB_TOKEN=ghp_...
